# OmerOpsMap — environment template
#
# Copy to `.env` (gitignored) and fill in real values.
# `.env` is read by docker-compose at startup; values flow into the data_server
# container as environment variables and are picked up by Pydantic Settings.

# ─── Core (REQUIRED in production — container fails to boot if blank) ────────
# Generate SECRET_KEY with:  python -c 'import secrets; print(secrets.token_urlsafe(64))'
SECRET_KEY=
# Database password — used by both the Postgres container and the asyncpg URL.
POSTGRES_PASSWORD=
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=
INITIAL_ADMIN_EMAIL=
INITIAL_SUBADMIN_USERNAME=power_user
INITIAL_SUBADMIN_PASSWORD=
INITIAL_SUBADMIN_EMAIL=

# ─── Frontend (production) ────────────────────────────────────────────────────
# In production these point at your public domain. In dev the override file
# overrides them to localhost:8001.
VITE_API_URL=https://your-domain.example
VITE_WS_URL=wss://your-domain.example/ws

# ─── External integrations (Phase 1.0) ────────────────────────────────────────
# Master switch — set to false to disable every integration job.
EXTERNAL_SYNC_ENABLED=true

# Geofence radius (km) around Omer center used by all sources unless the source
# overrides (e.g. TomTom uses 12 km internally to cover Beer Sheva access roads).
OMER_RADIUS_KM=5.0

# Pikud Haoref poll cadence
#   active = right after a hit (10 min window of accelerated polling)
#   idle   = baseline
OREF_ACTIVE_POLL_SECS=5
OREF_IDLE_POLL_SECS=30

# API keys — each integration self-disables if its key is blank, so safe to omit
# any source you do not yet have a key for.

# TomTom Traffic API — free tier: 2,500 requests/day
# Register at https://developer.tomtom.com (no credit card required)
TOMTOM_API_KEY=

# Open-Meteo — NO key required (kept here only for forward compatibility with
# OpenWeather as a paid fallback if Open-Meteo ever goes paid).
OPENWEATHER_API_KEY=

# IMS (Israel Meteorological Service) — register at https://ims.gov.il
IMS_API_TOKEN=

# NASA FIRMS (fires) — https://firms.modaps.eosdis.nasa.gov/api/area/
FIRMS_API_KEY=

# Google Maps Platform — Places + Roads.
# Required only for Phase 1.3 (Google Places). Costs apply beyond free credits.
GMAPS_API_KEY=

# Waze for Cities Connected Citizens Program (CCP) — gated to municipalities,
# obtained by signing a partnership agreement with Waze. Phase 2.0 only.
WAZE_PARTNER_TOKEN=
